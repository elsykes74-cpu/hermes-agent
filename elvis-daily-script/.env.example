# The King Lives — Elvis Pipeline Environment Variables
# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Script generation (OpenRouter → Claude) ──────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Voiceover (ElevenLabs) ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
# Get your voice ID from elevenlabs.io → Voices → click a voice → copy the ID
ELEVENLABS_VOICE_ID=...

# ── Scene images (Ideogram 4) ─────────────────────────────────────────────────
# Free account at developer.ideogram.ai — ~$0.03 per image, ~$0.21 per video
IDEOGRAM_API_KEY=...

# ── YouTube upload ────────────────────────────────────────────────────────────
# Path to your client_secret_*.json downloaded from Google Cloud Console
# Setup: GCP → APIs & Services → Credentials → Create → Desktop app → Download
# Enable: YouTube Data API v3 in your GCP project
YOUTUBE_CLIENT_SECRETS_FILE=/path/to/client_secret_123.json
